{
  "name": "diesel-guard",
  "displayName": "diesel-guard",
  "description": "Linter for dangerous Postgres migration patterns in Diesel and SQLx",
  "version": "0.9.0",
  "publisher": "ayarotsky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayarotsky/diesel-guard"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Linters"],
  "keywords": ["diesel", "sqlx", "postgres", "sql", "migration", "linter"],
  "activationEvents": ["onLanguage:sql"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "diesel-guard",
      "properties": {
        "diesel-guard.binaryPath": {
          "type": "string",
          "default": "diesel-guard",
          "description": "Path to the diesel-guard binary. Defaults to 'diesel-guard' (must be on PATH)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
